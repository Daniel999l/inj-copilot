# ─────────────────────────────────────────────────────────────
#  inj-copilot — environment configuration
#  Copy this file to ".env.local" and fill in what you need.
#  Everything here is OPTIONAL: the app runs and reads on-chain
#  data with zero config. The keys below only enable the
#  conversational AI layer and let you swap data endpoints.
# ─────────────────────────────────────────────────────────────

# ── AI copilot (any OpenAI-compatible endpoint) ──────────────
# Works with OpenAI, OpenRouter, Together, Groq, a local Ollama
# / vLLM server, or your own Vast.ai box running an
# OpenAI-compatible API. Leave LLM_API_KEY empty to fall back to
# the built-in deterministic (non-AI) analysis.
LLM_API_KEY=YOUR GROQ KEY HERE
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Examples of other providers:
#   OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1   LLM_MODEL=meta-llama/llama-3.1-8b-instruct
#   Local/vLLM:  LLM_BASE_URL=http://localhost:8000/v1       LLM_MODEL=your-served-model
#   Ollama:      LLM_BASE_URL=http://localhost:11434/v1      LLM_MODEL=llama3.1

# ── Injective data endpoints (sensible public defaults) ──────
# Cosmos LCD/REST — balances, staking, rewards.
INJ_LCD_URL=https://injective-rest.publicnode.com
# Indexer REST — perpetual positions (verify this host for your
# setup; positions are an optional enhancement and the app works
# without them).
INJ_INDEXER_URL=https://sentry.exchange.grpc-web.injective.network

# ── Price source (optional) ──────────────────────────────────
# CoinGecko public API is used by default with no key. If you
# have a CoinGecko key, set it to avoid public rate limits.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
